{
  "name": "@karate/local",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/standalone.ts",
    "dev:fresh": "pnpm --filter @karate/web build && tsx build-bundle.ts && KARATE_DEV=1 tsx src/standalone.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/standalone.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "tsx build-bundle.ts",
    "build:bin": "pnpm --filter @karate/web build && tsx build-bundle.ts --target=$TARGET && bun build --compile --target=$TARGET --outfile=dist-bin/kumiteos src/standalone.ts",
    "clean": "rm -rf dist dist-bin embedded .turbo node_modules"
  },
  "dependencies": {
    "@karate/core": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
